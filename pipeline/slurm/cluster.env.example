# =============================================================================
# cluster.env — site-specific SLURM settings for the hprv distributed run.
#
# Copy to cluster.env and fill in for YOUR cluster. submit_slurm.sh sources it.
# Nothing here is portable across sites; everything the pipeline itself needs
# (thresholds, resources) stays in your hprv config.yaml — this file is ONLY the
# scheduler + container-launch glue.
# =============================================================================

# --- what to run -------------------------------------------------------------
# IMPORTANT: HPRV_CONFIG must be a FULLY-RESOLVED config — literal paths, NOT ${ENV} placeholders.
# phase.sbatch launches every step with `apptainer exec --cleanenv`, which strips host env vars, so
# config.py inside the container cannot expand ${REF_FASTA}/${VEP_CACHE}/${CADD_*} and run_pipeline.sh
# dies at preflight ("... is unresolved"). Resolve them once before pointing HPRV_CONFIG here — e.g.
# source your resource env (prepare_resources.sh emit-env) and `envsubst < config.example.yaml > config.yaml`.
HPRV_CONFIG=/path/to/config.yaml        # your RESOLVED hprv config (literal paths, no ${ENV})
HPRV_WORK=/path/to/shared/hprv_run1     # run dir — MUST be on SHARED storage (all nodes see it):
                                        # the scatter tasks and the gather job run on different
                                        # nodes and exchange per-contig shards through here.

# --- SLURM account/partition -------------------------------------------------
SLURM_ACCOUNT=your_account
SLURM_PARTITION=your_partition
SLURM_QOS=                              # optional; leave empty to omit

# --- how to launch the container on a compute node ---------------------------
# One array task = one container launch. phase.sbatch runs each step as:
#     $HPRV_CONTAINER_BIN exec --cleanenv --bind $HPRV_BINDS $HPRV_SIF run_pipeline.sh ...
# Binds MUST cover the cache, CADD, reference, input VCFs, and $HPRV_WORK.
HPRV_CONTAINER_BIN=apptainer            # apptainer | singularity | "" (empty = native: tools on PATH)
APPTAINER_MODULE=apptainer              # `module load` name; empty to skip the module load
HPRV_SIF=/path/to/hprv.sif              # the pulled image (pull by @sha256 digest on HPC)
HPRV_BINDS=/path/to/data                # comma-separated bind paths (add wherever your data lives)

# --- per-phase resources (passed to sbatch; tune to your nodes) --------------
# scatter is the tall pole: one VEP+CADD run per contig, so size CPUS to a node
# and TIME to the LARGEST contig (chr1 ~= 8% of a WGS union — a few hours), not
# the whole genome. gather/downstream are light; prep does the union build.
PREP_CPUS=8;      PREP_MEM=32G;     PREP_TIME=24:00:00     # Steps 0-1 (union build; serial for now)
PLAN_CPUS=1;      PLAN_MEM=4G;      PLAN_TIME=00:20:00     # enumerate contigs + submit the DAG
SCATTER_CPUS=16;  SCATTER_MEM=32G;  SCATTER_TIME=06:00:00  # one contig of VEP+CADD (per array task)
GATHER_CPUS=4;    GATHER_MEM=16G;   GATHER_TIME=04:00:00   # concat shards + split-vep + output
DOWN_CPUS=8;      DOWN_MEM=32G;     DOWN_TIME=24:00:00     # the downstream job (Steps DOWN_FROM..DOWN_TO)

# Which steps the `downstream` job runs (default 3-8 = the whole tail). Narrow the range to end
# the distributed graph early — most commonly DOWN_TO=7 when Step 8 (mini-CRAM/igv export) needs a
# node the batch partition can't provide, e.g. a FUSE-mounted CRAM store visible only on
# login/interactive nodes. Then run Step 8 separately where the CRAMs live (see README.md).
DOWN_FROM=3
DOWN_TO=8

# Max scatter tasks running at once (the %K in --array=0-N%K). Set to how many
# nodes you want Step 2 to occupy concurrently.
SCATTER_CONCURRENCY=12

# CADD's per-variant tabix reads into the ~81 GB file are the per-shard
# bottleneck. If CADD lives on a network/FUSE mount, stage it to node-local disk
# in the scatter phase (a scontrol/rsync prologue) — see slurm/README.md.
