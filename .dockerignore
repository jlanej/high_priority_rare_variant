# Keep the Docker build context tiny and free of data/secrets.
.git
.github
docs
tests/data
results
work
logs
# Keep prepared resource DATA out of the context (it can be hundreds of GB), but let the pinned
# manifest through — the image ships prepare_resources.sh, which reads it. Use resources/* (not
# resources/) so the exception can re-include the file. Mirrors .gitignore.
resources/*
!resources/manifest.env
vep_cache
*.sif
*.vcf
*.vcf.gz
*.bam
*.cram
*.fasta
*.fa
config/*.yaml
!config/*.example.yaml
**/__pycache__
**/*.pyc
.venv
venv
.DS_Store
